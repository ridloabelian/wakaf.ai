# wakaf.ai Environment Configuration
# Copy to .env and fill in your values

# ============================================
# Database
# ============================================
POSTGRES_USER=wakaf
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=wakaf_ai

# ============================================
# Odoo ERP
# ============================================
ODOO_ADMIN_PASSWORD=your_odoo_admin_password

# ============================================
# N8N Workflow
# ============================================
N8N_USER=admin
N8N_PASSWORD=your_n8n_password

# ============================================
# AI Gateway (Cloudflare Workers)
# ============================================
AI_GATEWAY_URL=https://ai-gateway.your-subdomain.workers.dev
AI_GATEWAY_KEY=your_api_key

# ============================================
# Queue Engine (Cloudflare Workers)
# ============================================
QUEUE_URL=https://queue.your-subdomain.workers.dev

# ============================================
# Grafana Dashboard
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password
GRAFANA_URL=https://grafana.wakaf.ai

# ============================================
# LLM API Keys (for Cloudflare Workers secrets)
# ============================================
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ============================================
# Cloudflare
# ============================================
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ZONE_ID=your_zone_id

# ============================================
# Domain
# ============================================
DOMAIN=wakaf.ai
